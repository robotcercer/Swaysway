# ── Key bindings ─────────────────────────────────────────────
# [span_34](start_span)Applications[span_34](end_span)
[span_35](start_span)bindsym $mod+Return        exec $term[span_35](end_span)
[span_36](start_span)bindsym $mod+d             exec $menu[span_36](end_span)
[span_37](start_span)bindsym $mod+Shift+b       exec $browser[span_37](end_span)
[span_38](start_span)bindsym $mod+Shift+q       kill[span_38](end_span)
[span_39](start_span)bindsym $mod+Shift+r       reload[span_39](end_span)
bindsym $mod+Shift+e       exec swaynag -t warning -m "Выйти из Sway?" \
                                -[span_40](start_span)b "Да" "swaymsg exit"[span_40](end_span)

# [span_41](start_span)Volume  (auto-refresh waybar via SIGRTMIN+1)[span_41](end_span)
bindsym XF86AudioRaiseVolume  exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ \
                                    [span_42](start_span)&& pkill -RTMIN+1 waybar[span_42](end_span)
bindsym XF86AudioLowerVolume  exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- \
                                    [span_43](start_span)&& pkill -RTMIN+1 waybar[span_43](end_span)
bindsym XF86AudioMute         exec wpctl set-mute   @DEFAULT_AUDIO_SINK@ toggle \
                                    [span_44](start_span)&& pkill -RTMIN+1 waybar[span_44](end_span)
[span_45](start_span)bindsym XF86AudioMicMute      exec wpctl set-mute   @DEFAULT_SOURCE@ toggle[span_45](end_span)

# [span_46](start_span)Brightness  (auto-refresh waybar via SIGRTMIN+2)[span_46](end_span)
bindsym XF86MonBrightnessUp   exec light -A 5 \
                                    [span_47](start_span)&& pkill -RTMIN+2 waybar[span_47](end_span)
bindsym XF86MonBrightnessDown exec light -U 5 \
                                    [span_48](start_span)&& pkill -RTMIN+2 waybar[span_48](end_span)

