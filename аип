{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 2,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": [
        "custom/browser",
        "separator",
        "custom/gpu-temp",
        "temperature",
        "separator",
        "memory",
        "separator",
        "battery",
        "separator",
        "backlight",
        "separator",
        "pulseaudio",
        "tray"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}"
    },
    "sway/mode": {
        "format": " {}"
    },
    "clock": {
        "timezone": "Asia/Tashkent",
        "format": "  {:%H:%M}",
        "format-alt": "  {:%d %b %Y}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 1,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffffff'><b>{}</b></span>",
                "days": "<span color='#aaaaaa'>{}</span>",
                "weekdays": "<span color='#666666'>{}</span>",
                "today": "<span color='#ffffff'><b><u>{}</u></b></span>"
            }
        }
    },
    "memory": {
        "interval": 5,
        "format": " {used:0.1f}G",
        "tooltip-format": "RAM: {used:0.1f} / {total:0.1f} GB\nFree: {avail:0.1f} GB\nSwap: {swapUsed:0.1f} GB"
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 85,
        "format": " {temperatureC}آ°C",
        "format-critical": " {temperatureC}آ°C",
        "tooltip": true
    },
    "custom/gpu-temp": {
        "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null | awk '{printf \"َ°¢® %sآ°C\", $1}'",
        "interval": 5,
        "format": "{}",
        "tooltip-format": "NVIDIA RTX 4050",
        "return-type": ""
    },
    "battery": {
        "states": {
            "good": 90,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": ["َ°‚ژ","َ°پ؛","َ°پ»","َ°پ¼","َ°پ½","َ°پ¾","َ°پ؟","َ°‚€","َ°‚پ","َ°‚‚","َ°پ¹"],
        "tooltip-format": "{timeTo}\nCycles: {cycles}\nHealth: {health}%"
    },
    "backlight": {
        "device": "amdgpu_bl1",
        "format": "{icon} {percent}%",
        "format-icons": ["َ°ƒ‍","َ°ƒں","َ°ƒ "],
        "on-scroll-up": "light -A 5",
        "on-scroll-down": "light -U 5",
        "tooltip": false,
        "signal": 2
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "default": ["َ°•؟","َ°–€","َ°•¾"],
            "headphone": ["َ°‹‹"],
            "headset": ["َ°‹ژ"]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "scroll-step": 5,
        "signal": 1,
        "tooltip-format": "{desc}"
    },
    "custom/browser": {
        "format": "َ°–ں",
        "on-click": "firefox",
        "tooltip": false
    },
    "separator": {
        "format": " â”‚ "
    },
    "tray": {
        "spacing": 8,
        "show-passive-items": false
    }
}
