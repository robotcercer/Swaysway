{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 8,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": [
        "custom/gpu-temp",
        "separator",
        "temperature",
        "separator",
        "memory",
        "separator",
        "backlight",
        "separator",
        "pulseaudio",
        "separator",
        "battery",
        "tray"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{name}"
    },
    "clock": {
        "timezone": "Asia/Tashkent",
        "format": "{:%H:%M  |  %d.%m.%Y}",
        "tooltip": false
    },
    "custom/gpu-temp": {
        "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null | awk '{print \"GPU \"$1\"°C\"}'",
        "interval": 5,
        "format": "{}",
        "tooltip": false
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 85,
        "format": "CPU {temperatureC}°C",
        "tooltip": false
    },
    "memory": {
        "interval": 5,
        "format": "RAM {used:0.1f}G",
        "tooltip": false
    },
    "backlight": {
        "device": "amdgpu_bl1",
        "format": "BRT {percent}%",
        "on-scroll-up": "light -A 5",
        "on-scroll-down": "light -U 5",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-muted": "MUTE",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "scroll-step": 5,
        "tooltip": false
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT {capacity}%",
        "format-charging": "CHG {capacity}%",
        "format-plugged": "AC {capacity}%",
        "tooltip": false
    },
    "separator": {
        "format": "│"
    },
    "tray": {
        "spacing": 8
    }
}
